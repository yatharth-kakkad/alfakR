k = nn_common,
mean_a = nn_a[nn_common],
mean_b = nn_b[nn_common],
diff = nn_b[nn_common] - nn_a[nn_common]
)
nn_diff$abs_diff <- abs(nn_diff$diff)
nn_diff <- nn_diff[order(-nn_diff$abs_diff), , drop = FALSE]
nn_summary <- data.frame(
n_common = length(nn_common),
mean_abs_diff = if (length(nn_common) > 0) mean(nn_diff$abs_diff, na.rm = TRUE) else NA_real_,
median_abs_diff = if (length(nn_common) > 0) median(nn_diff$abs_diff, na.rm = TRUE) else NA_real_,
max_abs_diff = if (length(nn_common) > 0) max(nn_diff$abs_diff, na.rm = TRUE) else NA_real_
)
cat("\nNearest-neighbor fitness (f_nn) differences (mean across bootstraps):\n")
print(nn_summary)
write.csv(nn_diff, file.path(out_base, "f_nn_diff.csv"), row.names = FALSE)
land_a <- readRDS(file.path(out_a, "landscape.Rds"))
land_b <- readRDS(file.path(out_b, "landscape.Rds"))
land_merge <- merge(land_a, land_b, by = "k", suffixes = c("_a", "_b"))
land_merge$diff_mean <- land_merge$mean_b - land_merge$mean_a
land_merge$abs_diff_mean <- abs(land_merge$diff_mean)
land_merge <- land_merge[order(-land_merge$abs_diff_mean), , drop = FALSE]
land_summary <- data.frame(
n_common = nrow(land_merge),
mean_abs_diff = if (nrow(land_merge) > 0) mean(land_merge$abs_diff_mean, na.rm = TRUE) else NA_real_,
median_abs_diff = if (nrow(land_merge) > 0) median(land_merge$abs_diff_mean, na.rm = TRUE) else NA_real_,
max_abs_diff = if (nrow(land_merge) > 0) max(land_merge$abs_diff_mean, na.rm = TRUE) else NA_real_
)
cat("\nLandscape mean differences (landscape.Rds mean column):\n")
print(land_summary)
write.csv(land_merge, file.path(out_base, "landscape_mean_diff.csv"), row.names = FALSE)
cat("\nWrote outputs to:\n")
cat("  ", file.path(out_base, "f_nn_diff.csv"), "\n", sep = "")
cat("  ", file.path(out_base, "landscape_mean_diff.csv"), "\n", sep = "")
View(yi)
View(boot_a)
View(land_b)
View(land_summary)
View(land_a)
View(yi)
yi[["x"]]
View(land_b)
View(land_a)
View(land_b)
View(land_a)
View(land_b)
#!/usr/bin/env Rscript
# Compare passage_times = c(0, 180) vs 0:180 for f_nn and landscape summaries.
# Usage:
#   Rscript scripts/compare_passage_times.R path/to/yi.Rds
# Or source this file in an R session where `yi` is already defined.
x<-readRDS('/Users/4482173/Documents/GitHub/PANcanKFLs/Results/data/processed/ALFA_K/GBM/ALFA-K_inputs/P8.Rds')
x$x <- x$x[rownames(x$x) != '2.2.2.2.2.2.2.2.2.2.2.2.2.2.2.2.2.2.2.2.2.2', ]
if (dim(x$x)[1] <= 1) {
# Log warning about insufficient observations
log_msg <- paste0("[", format(Sys.time(), "%Y-%m-%d %H:%M:%S"), "] ",
patient_id, ": No enough observations, only ", dim(x$x)[1], " was observed\n")
cat(log_msg, file = paste0(workdir, "/Warming.log"), append = TRUE)
return(list(patient = patient_id, status = "insufficient_obs"))
}
x_combined <- do.call(cbind, x$x)
rownames(x_combined) <- rownames(x$x)
x$x <- x_combined
yi<-x
args <- commandArgs(trailingOnly = TRUE)
if (!exists("yi")) {
if (length(args) > 0 && file.exists(args[1])) {
yi <- readRDS(args[1])
} else {
stop("Provide `yi` in the environment or pass a path to an RDS file.")
}
}
if (!is.list(yi) || is.null(yi$x)) {
stop("`yi` must be a list with element `x` (counts matrix).")
}
if (is.null(colnames(yi$x))) {
stop("`yi$x` must have colnames for timepoints.")
}
if (!exists("alfak")) {
source(file.path("R", "ALFA-K.R"))
}
minobs <- 20
nboot <- 45
n0 <- 1e5
nb <- 1e7
#pm <- 0.00005
pm <- 0.016
out_base <- "passage_times_compare"
out_a <- file.path(out_base, "passage_0_180")
out_b <- file.path(out_base, "passage_0_1_..._180")
dir.create(out_a, recursive = TRUE, showWarnings = FALSE)
dir.create(out_b, recursive = TRUE, showWarnings = FALSE)
cat("Running alfak with passage_times = c(0, 180)...\n")
alfak(
yi = yi,
outdir = out_a,
passage_times = c(0, 180),
minobs = minobs,
nboot = nboot,
n0 = n0,
nb = nb,
pm = pm
)
cat("Running alfak with passage_times = 0:180...\n")
alfak(
yi = yi,
outdir = out_b,
passage_times = 0:180,
minobs = minobs,
nboot = nboot,
n0 = n0,
nb = nb,
pm = pm
)
boot_a <- readRDS(file.path(out_a, "bootstrap_res.Rds"))
boot_b <- readRDS(file.path(out_b, "bootstrap_res.Rds"))
summarize_nn <- function(nn_mat) {
if (is.null(nn_mat) || ncol(nn_mat) == 0) {
return(setNames(numeric(0), character(0)))
}
colMeans(nn_mat, na.rm = TRUE)
}
nn_a <- summarize_nn(boot_a$nn_fitness)
nn_b <- summarize_nn(boot_b$nn_fitness)
nn_common <- intersect(names(nn_a), names(nn_b))
nn_diff <- data.frame(
k = nn_common,
mean_a = nn_a[nn_common],
mean_b = nn_b[nn_common],
diff = nn_b[nn_common] - nn_a[nn_common]
)
nn_diff$abs_diff <- abs(nn_diff$diff)
nn_diff <- nn_diff[order(-nn_diff$abs_diff), , drop = FALSE]
nn_summary <- data.frame(
n_common = length(nn_common),
mean_abs_diff = if (length(nn_common) > 0) mean(nn_diff$abs_diff, na.rm = TRUE) else NA_real_,
median_abs_diff = if (length(nn_common) > 0) median(nn_diff$abs_diff, na.rm = TRUE) else NA_real_,
max_abs_diff = if (length(nn_common) > 0) max(nn_diff$abs_diff, na.rm = TRUE) else NA_real_
)
cat("\nNearest-neighbor fitness (f_nn) differences (mean across bootstraps):\n")
print(nn_summary)
write.csv(nn_diff, file.path(out_base, "f_nn_diff.csv"), row.names = FALSE)
land_a <- readRDS(file.path(out_a, "landscape.Rds"))
land_b <- readRDS(file.path(out_b, "landscape.Rds"))
land_merge <- merge(land_a, land_b, by = "k", suffixes = c("_a", "_b"))
land_merge$diff_mean <- land_merge$mean_b - land_merge$mean_a
land_merge$abs_diff_mean <- abs(land_merge$diff_mean)
land_merge <- land_merge[order(-land_merge$abs_diff_mean), , drop = FALSE]
land_summary <- data.frame(
n_common = nrow(land_merge),
mean_abs_diff = if (nrow(land_merge) > 0) mean(land_merge$abs_diff_mean, na.rm = TRUE) else NA_real_,
median_abs_diff = if (nrow(land_merge) > 0) median(land_merge$abs_diff_mean, na.rm = TRUE) else NA_real_,
max_abs_diff = if (nrow(land_merge) > 0) max(land_merge$abs_diff_mean, na.rm = TRUE) else NA_real_
)
cat("\nLandscape mean differences (landscape.Rds mean column):\n")
print(land_summary)
write.csv(land_merge, file.path(out_base, "landscape_mean_diff.csv"), row.names = FALSE)
cat("\nWrote outputs to:\n")
cat("  ", file.path(out_base, "f_nn_diff.csv"), "\n", sep = "")
cat("  ", file.path(out_base, "landscape_mean_diff.csv"), "\n", sep = "")
View(land_b)
